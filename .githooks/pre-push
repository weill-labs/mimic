#!/bin/bash
set -euo pipefail

warn_if_origin_main_drifted() {
    if ! command -v gh >/dev/null 2>&1; then
        return 0
    fi

    local local_origin_main_sha
    local github_main_sha

    local_origin_main_sha="$(git rev-parse --verify refs/remotes/origin/main 2>/dev/null || true)"
    github_main_sha="$(gh api repos/weill-labs/mimic/git/ref/heads/main --jq .object.sha 2>/dev/null || true)"

    if [[ -z "$local_origin_main_sha" || -z "$github_main_sha" || "$local_origin_main_sha" == "$github_main_sha" ]]; then
        return 0
    fi

    echo "WARNING: local origin/main (${local_origin_main_sha:0:12}) differs from GitHub main (${github_main_sha:0:12})." >&2
    echo "  Refresh before rebasing with:" >&2
    echo "  git fetch git@github.com:weill-labs/mimic.git main:refs/remotes/origin/main" >&2
    echo "  git rebase origin/main" >&2
}

branch_update=false
while read -r local_ref _remote_sha remote_ref _local_sha; do
    if [[ "$local_ref" == refs/heads/* ]] || [[ "$remote_ref" == refs/heads/* ]]; then
        branch_update=true
    fi
done

if [[ "$branch_update" != true ]]; then
    exit 0
fi

warn_if_origin_main_drifted

exit 0
